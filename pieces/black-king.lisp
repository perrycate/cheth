;; Claude generated, to avoid having to add a new dependency for rendering piece images.

(defun draw-black-king (x y size)
  "Draw a black king at position (X, Y) scaled to SIZE.
   The piece is drawn within a SIZE x SIZE square with its top-left at (X, Y).
   Assumes cl-cairo2 is loaded and *context* is bound."
  (let ((s (/ size 1000.0)))            ; SVG viewBox is 1000x1000
    (save)
    (translate x y)
    (scale s s)

    ;; White border stroke
    (set-source-rgb 1 1 1)
    (set-line-width 30)
    (set-line-join :round)
    (set-line-cap :round)
    (move-to 56 495)
    (curve-to 56 403 127 364 208 364)
    (curve-to 269 364 320 384 377 422)
    (line-to 379 420)
    (curve-to 379 420 368 393 368 358)
    (curve-to 368 308 388 241 470 223)
    (line-to 470 181)
    (line-to 410 181)
    (line-to 410 121)
    (line-to 470 121)
    (line-to 470 61)
    (line-to 530 61)
    (line-to 530 121)
    (line-to 590 121)
    (line-to 590 181)
    (line-to 530 181)
    (line-to 530 223)
    (curve-to 612 241 632 308 632 358)
    (curve-to 632 393 621 420 621 420)
    (line-to 623 422)
    (curve-to 680 384 731 364 792 364)
    (curve-to 873 364 944 403 944 495)
    (curve-to 944 622 869 693 804 730)
    (line-to 782 868)
    (curve-to 770 898 705 939 500 939)
    (curve-to 295 939 230 898 218 868)
    (line-to 196 730)
    (curve-to 131 693 56 622 56 495)
    (stroke)

    ;; Outer path: white fill
    (set-source-rgb 1 1 1)
    (move-to 56 495)
    (curve-to 56 403 127 364 208 364)
    (curve-to 269 364 320 384 377 422)
    (line-to 379 420)
    (curve-to 379 420 368 393 368 358)
    (curve-to 368 308 388 241 470 223)
    (line-to 470 181)
    (line-to 410 181)
    (line-to 410 121)
    (line-to 470 121)
    (line-to 470 61)
    (line-to 530 61)
    (line-to 530 121)
    (line-to 590 121)
    (line-to 590 181)
    (line-to 530 181)
    (line-to 530 223)
    (curve-to 612 241 632 308 632 358)
    (curve-to 632 393 621 420 621 420)
    (line-to 623 422)
    (curve-to 680 384 731 364 792 364)
    (curve-to 873 364 944 403 944 495)
    (curve-to 944 622 869 693 804 730)
    (line-to 782 868)
    (curve-to 770 898 705 939 500 939)
    (curve-to 295 939 230 898 218 868)
    (line-to 196 730)
    (curve-to 131 693 56 622 56 495)
    (fill-path)

    ;; Black outline path with inner cutouts (nonzero fill rule)
    (set-source-rgb 0 0 0)

    ;; Outer subpath (clockwise)
    (move-to 56 495)
    (curve-to 56 403 127 364 208 364)
    (curve-to 269 364 320 384 377 422)
    (line-to 379 420)
    (curve-to 379 420 368 393 368 358)
    (curve-to 368 308 388 241 470 223)
    (line-to 470 181)
    (line-to 410 181)
    (line-to 410 121)
    (line-to 470 121)
    (line-to 470 61)
    (line-to 530 61)
    (line-to 530 121)
    (line-to 590 121)
    (line-to 590 181)
    (line-to 530 181)
    (line-to 530 223)
    (curve-to 612 241 632 308 632 358)
    (curve-to 632 393 621 420 621 420)
    (line-to 623 422)
    (curve-to 680 384 731 364 792 364)
    (curve-to 873 364 944 403 944 495)
    (curve-to 944 622 869 693 804 730)
    (line-to 782 868)
    (curve-to 770 898 705 939 500 939)
    (curve-to 295 939 230 898 218 868)
    (line-to 196 730)
    (curve-to 131 693 56 622 56 495)

    ;; Inner subpath: left wing
    (new-sub-path)
    (move-to 116 505)
    (curve-to 116 599 170 652 225 684)
    (curve-to 291 664 391 656 470 656)
    (curve-to 450 495 289 424 218 424)
    (curve-to 147 424 116 453 116 505)

    ;; Inner subpath: left wing highlight
    (new-sub-path)
    (move-to 150 519)
    (curve-to 150 489 168 457 208 457)
    (curve-to 319 457 413 555 427 628)
    (curve-to 356 628 287 634 231 650)
    (curve-to 168 612 150 549 150 519)

    ;; Inner subpath: waist band
    (new-sub-path)
    (move-to 258 797)
    (line-to 264 840)
    (curve-to 360 825 428 819 500 819)
    (curve-to 572 819 640 825 736 840)
    (line-to 742 797)
    (curve-to 652 780 577 773 500 773)
