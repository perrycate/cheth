;; Claude generated, to avoid having to add a new dependency for rendering piece images.

(defun draw-black-knight (x y size)
  "Draw a black knight at position (X, Y) scaled to SIZE.
   The piece is drawn within a SIZE x SIZE square with its top-left at (X, Y).
   Assumes cl-cairo2 is loaded and *context* is bound."
  (let ((s (/ size 1000.0)))            ; SVG viewBox is 1000x1000
    (save)
    (translate x y)
    (scale s s)

    ;; Outer path: white fill
    (set-source-rgb 1 1 1)
    (move-to 120 641)
    (curve-to 120 607 137 571 160 528)
    (curve-to 182 486 202 433 216 372)
    (curve-to 245 253 278 238 296 232)
    (line-to 296 145)
    (line-to 300 145)
    (line-to 384 212)
    (line-to 388 212)
    (line-to 438 122)
    (line-to 440 122)
    (line-to 491 229)
    (curve-to 502 226 514 224 526 224)
    (curve-to 732 224 850 576 882 892)
    (line-to 331 892)
    (curve-to 331 814 359 762 384 718)
    (curve-to 403 684 420 651 420 618)
    (line-to 420 608)
    (line-to 305 692)
    (curve-to 278 725 249 740 226 740)
    (curve-to 211 740 198 733 191 720)
    (curve-to 187 721 183 721 179 721)
    (curve-to 147 721 120 693 120 641)
    (fill-path)

    ;; Black outline path with inner cutouts (nonzero fill rule)
    (set-source-rgb 0 0 0)

    ;; Outer subpath (clockwise)
    (move-to 120 641)
    (curve-to 120 607 137 571 160 528)
    (curve-to 182 486 202 433 216 372)
    (curve-to 245 253 278 238 296 232)
    (line-to 296 145)
    (line-to 300 145)
    (line-to 384 212)
    (line-to 388 212)
    (line-to 438 122)
    (line-to 440 122)
    (line-to 491 229)
    (curve-to 502 226 514 224 526 224)
    (curve-to 732 224 850 576 882 892)
    (line-to 331 892)
    (curve-to 331 814 359 762 384 718)
    (curve-to 403 684 420 651 420 618)
    (line-to 420 608)
    (line-to 305 692)
    (curve-to 278 725 249 740 226 740)
    (curve-to 211 740 198 733 191 720)
    (curve-to 187 721 183 721 179 721)
    (curve-to 147 721 120 693 120 641)

    ;; Inner subpath: eye
    (new-sub-path)
    (move-to 191 625)
    (curve-to 191 631 196 638 201 638)
    (curve-to 205 638 210 632 214 627)
    (curve-to 222 618 222 618 228 616)
    (curve-to 234 614 243 611 243 605)
    (curve-to 243 598 234 592 228 592)
    (curve-to 198 592 191 620 191 625)

    ;; Inner subpath: nostril
    (new-sub-path)
    (move-to 295 436)
    (line-to 310 436)
    (curve-to 352 436 381 412 381 337)
    (curve-to 381 325 380 317 380 317)
    (curve-to 375 320 369 323 363 326)
    (curve-to 332 341 295 359 295 436)

    ;; Inner subpath: highlight on body
    (new-sub-path)
    (move-to 494 276)
    (curve-to 494 290 507 296 525 296)
    (curve-to 575 296 647 369 702 487)
    (curve-to 752 596 787 786 787 850)
    (curve-to 787 864 797 867 806 867)
    (curve-to 814 867 830 863 830 855)
    (curve-to 830 763 790 584 743 477)
    (curve-to 685 345 600 260 531 260)
    (curve-to 511 260 494 263 494 276)
    (fill-path)

    (restore)))
