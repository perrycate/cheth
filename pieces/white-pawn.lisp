;; Claude generated, to avoid having to add a new dependency for rendering piece images.

(defun draw-white-pawn (x y size)
  "Draw a white pawn at position (X, Y) scaled to SIZE.
   The pawn is drawn within a SIZE x SIZE square with its top-left at (X, Y).
   Assumes cl-cairo2 is loaded and *context* is bound."
  (let ((s (/ size 1000.0)))            ; SVG viewBox is 1000x1000
    (save)
    (translate x y)
    (scale s s)

    ;; Outer path: white fill
    (set-source-rgb 1 1 1)
    (move-to 188 910)
    (line-to 188 769)
    (curve-to 188 704 218 578 339 528)
    (line-to 339 525)
    (curve-to 316 497 303 461 303 423)
    (curve-to 303 375 324 324 379 285)
    (line-to 379 283)
    (curve-to 373 273 364 250 364 231)
    (curve-to 364 170 401 105 500 105)
    (curve-to 599 105 636 170 636 231)
    (curve-to 636 250 627 273 621 283)
    (line-to 621 285)
    (curve-to 676 324 697 375 697 423)
    (curve-to 697 461 684 497 661 525)
    (line-to 661 528)
    (curve-to 782 578 812 704 812 769)
    (line-to 812 910)
    (line-to 188 910)
    (fill-path)

    ;; Black outline path with inner cutout (nonzero fill rule)
    (set-source-rgb 0 0 0)

    ;; Outer subpath (clockwise)
    (move-to 188 910)
    (line-to 188 769)
    (curve-to 188 704 218 578 339 528)
    (line-to 339 525)
    (curve-to 316 497 303 461 303 423)
    (curve-to 303 375 324 324 379 285)
    (line-to 379 283)
    (curve-to 373 273 364 250 364 231)
    (curve-to 364 170 401 105 500 105)
    (curve-to 599 105 636 170 636 231)
    (curve-to 636 250 627 273 621 283)
    (line-to 621 285)
    (curve-to 676 324 697 375 697 423)
    (curve-to 697 461 684 497 661 525)
    (line-to 661 528)
    (curve-to 782 578 812 704 812 769)
    (line-to 812 910)
    (line-to 188 910)

    ;; Inner subpath (counter-clockwise cutout)
    (new-sub-path)
    (move-to 248 850)
    (line-to 752 850)
    (line-to 752 749)
    (curve-to 752 672 685 576 581 548)
    (line-to 581 544)
    (curve-to 610 514 633 470 633 424)
    (curve-to 633 377 611 331 550 306)
    (line-to 550 304)
    (curve-to 566 289 576 263 576 239)
    (curve-to 576 201 554 165 500 165)
    (curve-to 446 165 424 201 424 239)
    (curve-to 424 263 434 289 450 304)
    (line-to 450 306)
    (curve-to 389 331 367 377 367 424)
    (curve-to 367 470 390 514 419 544)
    (line-to 419 548)
    (curve-to 315 576 248 672 248 749)
    (line-to 248 850)
    (fill-path)

    (restore)))
